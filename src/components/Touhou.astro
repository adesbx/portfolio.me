---
const baseUrl = import.meta.env.BASE_URL;
const cleanBase = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const scriptPath = `${cleanBase}touhou_-1_rust.js`;
---

<div 
  id="touhou-launcher-zone" 
  class="w-full max-w-md p-5 bg-zinc-900 border border-zinc-800 rounded-2xl shadow-xl my-4 text-left"
>
  <div class="flex items-center gap-3 mb-4">
    <div class="p-2 bg-emerald-950 border border-emerald-800 text-emerald-400 rounded-xl">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75 16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z" />
      </svg>
    </div>
    <div>
      <h3 class="text-sm font-bold text-white">Touhou -1 Prototype</h3>
      <p class="text-xs text-zinc-500">Moteur Rust & Bevy (WASM)</p>
    </div>
  </div>

  <div class="bg-zinc-950 border border-zinc-800/80 rounded-xl p-4 mb-4 font-mono text-xs text-zinc-300 shadow-inner">
    <div class="text-emerald-500 font-bold uppercase tracking-wider text-[10px] mb-2.5 flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
      Configuration des contrôles
    </div>
    <ul class="space-y-2 text-zinc-400">
      <li class="flex justify-between border-b border-zinc-900 pb-1.5">
        <span class="text-zinc-300 font-sans">Se déplacer</span>
        <span class="text-emerald-400 bg-zinc-900 px-2 py-0.5 rounded border border-zinc-800 font-bold">Z Q S D</span>
      </li>
      <li class="flex justify-between border-b border-zinc-900 pb-1.5">
        <span class="text-zinc-300 font-sans">Tirer</span>
        <span class="text-emerald-400 bg-zinc-900 px-2 py-0.5 rounded border border-zinc-800 font-bold">K</span>
      </li>
      <li class="flex justify-between border-b border-zinc-900 pb-1.5">
        <span class="text-zinc-300 font-sans">Bombe</span>
        <span class="text-emerald-400 bg-zinc-900 px-2 py-0.5 rounded border border-zinc-800 font-bold">L</span>
      </li>
      <li class="flex justify-between">
        <span class="text-zinc-300 font-sans">Ralentir</span>
        <span class="text-emerald-400 bg-zinc-900 px-2 py-0.5 rounded border border-zinc-800 font-bold">Shift Gauche</span>
      </li>
      <li class="flex justify-between">
        <span class="text-zinc-300 font-sans">Voir la Hit Box</span>
        <span class="text-emerald-400 bg-zinc-900 px-2 py-0.5 rounded border border-zinc-800 font-bold">Y</span>
      </li>
      <li class="flex justify-between">
        <span class="text-zinc-300 font-sans">Couper la musique</span>
        <span class="text-emerald-400 bg-zinc-900 px-2 py-0.5 rounded border border-zinc-800 font-bold">T</span>
      </li>
      <li class="flex justify-between">
        <span class="text-zinc-300 font-sans">Menu</span>
        <span class="text-emerald-400 bg-zinc-900 px-2 py-0.5 rounded border border-zinc-800 font-bold">Echap</span>
      </li>
    </ul>
  </div>

  <button 
    id="open-game-btn"
    class="w-full flex items-center justify-center gap-2 px-5 py-3 font-semibold text-sm text-white bg-emerald-600 hover:bg-emerald-500 active:scale-95 rounded-xl shadow-md transition-all cursor-pointer"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
      <path fill-rule="evenodd" d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" clip-rule="evenodd" />
    </svg>
    Lancer le prototype
  </button>
</div>

<div id="bevy-teleport-modal" class="hidden">
  <div id="game-backdrop" class="fixed inset-0 bg-zinc-950/95 backdrop-blur-md" style="z-index: 99990;"></div>

  <div id="game-modal-loading" class="fixed inset-0 flex flex-col items-center justify-center text-white gap-3 pointer-events-none" style="z-index: 99992;">
    <svg class="animate-spin h-8 w-8 text-emerald-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
    <p class="text-xs font-mono font-medium text-zinc-400 uppercase tracking-wider">Loading Bevy WebGL2 Engine...</p>
  </div>

  <div id="game-controls" class="fixed top-6 right-6 flex items-center gap-2 bg-zinc-900/95 p-2 rounded-2xl border border-zinc-800 shadow-2xl backdrop-blur-md" style="z-index: 99999;">
    <button 
      id="modal-close-btn" 
      class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-red-600 hover:bg-red-500 active:scale-95 text-white font-bold text-xs shadow-lg shadow-red-950/40 transition-all cursor-pointer border border-red-500/30"
      title="Fermer le jeu et revenir au site"
    >
      <span>Quitter le jeu</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
        <path fill-rule="evenodd" d="M5.47 5.47a.75.75 0 0 1 1.06 0L12 10.94l5.47-5.47a.75.75 0 1 1 1.06 1.06L13.06 12l5.47 5.47a.75.75 0 1 1-1.06 1.06L12 13.06l-5.47 5.47a.75.75 0 0 1-1.06-1.06L10.94 12 5.47 6.53a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
      </svg>
    </button>
  </div>
</div>

<canvas id="canvas" class="hidden"></canvas>

<script define:vars={{ scriptPath }} type="module">
  const openBtn = document.getElementById('open-game-btn');
  const modalWrapper = document.getElementById('bevy-teleport-modal');
  const backdrop = document.getElementById('game-backdrop');
  const loading = document.getElementById('game-modal-loading');
  const controls = document.getElementById('game-controls');
  const closeBtn = document.getElementById('modal-close-btn');
  
  let gameCanvas = null;
  let wasmInitialized = false;
  let audioCtx = null;

  if (modalWrapper && document.body) {
    document.body.appendChild(modalWrapper);
  }

  const OriginalAudioContext = window.AudioContext || window.webkitAudioContext;
  if (OriginalAudioContext && !window.AudioContextPatched) {
    window.AudioContext = function(...args) {
      const ctx = new OriginalAudioContext(...args);
      audioCtx = ctx;
      return ctx;
    };
    window.AudioContextPatched = true;
  }

  const observer = new MutationObserver((mutations) => {
    for (const mutation of mutations) {
      for (const node of mutation.addedNodes) {
        if (node.tagName === 'CANVAS') {
          const fallback = document.getElementById('canvas');
          if (fallback && fallback !== node) fallback.remove();

          gameCanvas = node;
          gameCanvas.classList.add('bevy-native-layer');
          gameCanvas.setAttribute('tabindex', '0');
          observer.disconnect();
        }
      }
    }
  });

  openBtn.addEventListener('click', async () => {
    const dialog = document.querySelector("dialog[open]");

    dialog?.close();
    
    modalWrapper.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    if (!wasmInitialized) {
      loading.style.display = 'flex';
      observer.observe(document.body, { childList: true });

      try {
        const wasmModule = await import(scriptPath);
        await wasmModule.default();
        wasmInitialized = true;
        loading.style.display = 'none';
      } catch (err) {
        console.error("Échec du moteur Bevy:", err);
        loading.style.display = 'none';
        closeModal();
        return;
      }
    }

    if (gameCanvas) {
      gameCanvas.style.setProperty('display', 'block', 'important');
      gameCanvas.focus();
    }
    
    if (audioCtx && audioCtx.state === 'suspended') {
      await audioCtx.resume();
    }
  });

  async function closeModal() {
    modalWrapper.classList.add('hidden');
    document.body.style.overflow = '';
    
    
    if (gameCanvas) {
      gameCanvas.style.setProperty('display', 'none', 'important');
    }
    
    if (audioCtx && audioCtx.state === 'running') {
      await audioCtx.suspend();
    }
    window.focus();
  }

  closeBtn.addEventListener('click', closeModal);
</script>

<style is:global>
  .bevy-native-layer {
    position: fixed !important;
    top: 50% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    z-index: 99995 !important; 
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.9);
    border-radius: 12px;
    background-color: #000;
    max-width: 95vw !important;
    max-height: 85vh !important;
  }
</style>