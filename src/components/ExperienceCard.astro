---
interface Props {
    date: string;
    title: string;
    company: string;
    tasks?: string[];
    link?: string;
    description?: string;
}

const { date, title, company, tasks = [], link, description } = Astro.props;
---

<div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1 sm:gap-6 py-2">
    <span class="text-xs font-mono text-zinc-400 dark:text-zinc-500 shrink-0 sm:w-32 pt-0.5">
        {date}
    </span>
    
    <div class="flex-1 space-y-3">
        <h3 class="text-sm font-semibold text-zinc-950 dark:text-white">
            {title} — <span class="text-zinc-500 dark:text-zinc-400 font-normal">{company}</span>
        </h3>
        
        {tasks.length > 0 && (
            <ul class="space-y-3">
                {tasks.map((task) => {
                    const hasColon = task.includes(" : ");
                    const [prefix, ...rest] = task.split(" : ");
                    const suffix = rest.join(" : ");

                    return (
                        <li class="text-xs text-zinc-700 dark:text-zinc-300 font-normal leading-relaxed flex items-start gap-2">
                            <span class="text-zinc-400 dark:text-zinc-600 select-none pt-0.5">•</span>
                            <span>
                                {hasColon ? (
                                    <>
                                        <strong class="font-bold text-zinc-950 dark:text-white">{prefix} :</strong> 
                                        {" "}{suffix}
                                    </>
                                ) : (
                                    task
                                )}
                            </span>
                        </li>
                    );
                })}
            </ul>
        )}

        {link && (
            <div class="pt-1">
                <a 
                    href={link} 
                    target="_blank" 
                    class="inline-flex items-center gap-1.5 text-[11px] text-zinc-400 dark:text-zinc-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-medium group cursor-pointer"
                >
                    <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                    <span>Lire le rapport de stage</span>
                    <svg class="w-3 h-3 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </a>
            </div>
        )}

        {description && (
            <div class="pt-1">
                <div class="inline-flex items-center gap-1.5 text-xs text-zinc-500 dark:text-zinc-400 font-medium select-none">
                    <svg class="w-3.5 h-3.5 text-zinc-400 dark:text-zinc-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                    <span>{description}</span>
                </div>
            </div>
        )}
    </div>
</div>